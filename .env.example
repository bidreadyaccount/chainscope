# =============================================================================
# ChainScope environment configuration
# Copy to `.env` and adjust. Never commit a real `.env`.
# All variables are validated at startup by packages/config (Zod). Invalid or
# missing required values cause a fast, explicit failure.
# =============================================================================

# -----------------------------------------------------------------------------
# Data mode
# -----------------------------------------------------------------------------
# "demo" (default) runs entirely on the deterministic demo-data generator and
# needs no RPC provider or DEX addresses. "live" indexes Robinhood Chain and
# REQUIRES a working RPC URL plus verified DEX + stablecoin addresses below.
DATA_MODE=demo

# -----------------------------------------------------------------------------
# Datastores (required in both demo and live modes)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://chainscope:chainscope@localhost:5432/chainscope
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Robinhood Chain RPC (required only when DATA_MODE=live)
# -----------------------------------------------------------------------------
# UNVERIFIED defaults — operators MUST confirm against
# https://docs.robinhood.com/chain before live use.
#   chainId  : 4663
#   RPC      : https://rpc.mainnet.chain.robinhood.com
#   Explorer : https://robinhoodchain.blockscout.com
ROBINHOOD_RPC_URL=
# Optional WebSocket endpoint for live log subscriptions (falls back to polling).
ROBINHOOD_WS_URL=

# Number of confirmations before a block is treated as final (reorg safety).
CHAIN_CONFIRMATIONS=5
# RPC poll interval (ms) when no WebSocket subscription is available.
CHAIN_POLL_INTERVAL_MS=2000

# -----------------------------------------------------------------------------
# DEX + token addresses (LIVE MODE ONLY — leave EMPTY until verified)
# -----------------------------------------------------------------------------
# !!! DO NOT INVENT THESE ADDRESSES. !!!
# No verified Robinhood Chain DEX, router, factory or stablecoin addresses are
# known at build time. Supply them ONLY from official, verified sources. While
# these are empty and DATA_MODE=live, the indexer has nothing to decode and the
# app should be run in demo mode instead.
#
# Comma-separated lists are allowed where multiple addresses apply.

# Uniswap V2-style factory / router (0x...):
ROBINHOOD_UNIV2_FACTORY=
ROBINHOOD_UNIV2_ROUTER=

# Uniswap V3-style factory / router / quoter (0x...):
ROBINHOOD_UNIV3_FACTORY=
ROBINHOOD_UNIV3_ROUTER=
ROBINHOOD_UNIV3_QUOTER=

# Canonical wrapped-native (WETH-equivalent) token (0x...):
ROBINHOOD_WRAPPED_NATIVE=

# Stablecoin token addresses used as USD price anchors (comma-separated 0x...):
ROBINHOOD_STABLECOINS=

# Trusted native-ETH USD reference price feed URL (optional; used for pricing).
ETH_USD_PRICE_FEED_URL=

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
# Comma-separated list of allowed CORS origins (the web app origin).
WEB_ORIGIN=http://localhost:3000
# Rate limit: max requests per window per IP.
API_RATE_LIMIT_MAX=200
API_RATE_LIMIT_WINDOW=1 minute

# -----------------------------------------------------------------------------
# Web app
# -----------------------------------------------------------------------------
# Base URL the browser uses to reach the API (REST).
NEXT_PUBLIC_API_URL=http://localhost:4000
# WebSocket URL the browser uses for the live stream.
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# -----------------------------------------------------------------------------
# Demo streaming
# -----------------------------------------------------------------------------
# Interval (ms) between synthetic live trades emitted in demo mode.
DEMO_STREAM_INTERVAL_MS=2500
# Fixed PRNG seed for reproducible demo datasets.
DEMO_SEED=1337

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# one of: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
NODE_ENV=development
