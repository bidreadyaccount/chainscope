{
  "name": "chainscope",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time onchain market-intelligence platform for Robinhood Chain",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @chainscope/database generate",
    "db:migrate": "pnpm --filter @chainscope/database migrate",
    "db:seed": "pnpm --filter @chainscope/database seed",
    "db:reset": "pnpm --filter @chainscope/database reset"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@types/node": "22.10.5",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "9.18.0",
    "eslint-config-prettier": "9.1.0",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0",
    "vitest": "2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
